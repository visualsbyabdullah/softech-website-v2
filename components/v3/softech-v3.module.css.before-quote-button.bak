.site {
  --v3-black: #080807;
  --v3-ink: #e8e8e3;
  --v3-muted: rgba(232, 232, 227, 0.58);
  --v3-line: rgba(232, 232, 227, 0.18);
  --v3-red: #b4161e;
  --v3-cream: #e8e8e3;

  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: var(--v3-black);
  color: var(--v3-ink);
}

.site::before {
  position: fixed;
  z-index: 100;
  inset: 0;
  pointer-events: none;
  content: "";
  opacity: 0.045;
  background-image:
    repeating-radial-gradient(
      circle at 20% 30%,
      transparent 0,
      rgba(255, 255, 255, 0.18) 1px,
      transparent 2px,
      transparent 5px
    );
  background-size: 7px 7px;
  mix-blend-mode: soft-light;
}

.header {
  position: absolute;
  z-index: 30;
  top: 0;
  right: 0;
  left: 0;
  height: 92px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 30px;
  padding: 0 clamp(22px, 3.5vw, 58px);
  border-bottom: 1px solid var(--v3-line);
}

.brand {
  width: fit-content;
  display: inline-flex;
  align-items: center;
  gap: 13px;
}

.brandMark {
  width: 39px;
  height: 39px;
  display: grid;
  place-items: center;
  background: var(--v3-ink);
  color: var(--v3-black);
  font-size: 18px;
  font-weight: 800;
}

.brand > span:last-child {
  display: flex;
  flex-direction: column;
}

.brand strong {
  font-size: 12px;
  line-height: 1;
  letter-spacing: 0.12em;
}

.brand small {
  margin-top: 5px;
  color: var(--v3-muted);
  font-size: 8px;
  letter-spacing: 0.08em;
}

.navigation {
  display: flex;
  align-items: center;
  gap: clamp(20px, 2.5vw, 42px);
}

.navigation a {
  position: relative;
  padding: 8px 0;
  color: var(--v3-muted);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: color 220ms ease;
}

.navigation a::after {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 1px;
  content: "";
  background: var(--v3-ink);
  transform: scaleX(0);
  transform-origin: right;
  transition: transform 350ms cubic-bezier(0.22, 1, 0.36, 1);
}

.navigation a:hover {
  color: var(--v3-ink);
}

.navigation a:hover::after {
  transform: scaleX(1);
  transform-origin: left;
}

.menuButton {
  justify-self: end;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 17px;
  border: 1px solid var(--v3-line);
  border-radius: 999px;
  background: transparent;
  color: var(--v3-ink);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition:
    background 250ms ease,
    color 250ms ease;
}

.menuButton:hover {
  background: var(--v3-ink);
  color: var(--v3-black);
}

.menuOverlay {
  position: fixed;
  z-index: 80;
  inset: 0;
  display: flex;
  flex-direction: column;
  padding: clamp(28px, 5vw, 80px);
  background: var(--v3-cream);
  color: var(--v3-black);
  visibility: hidden;
  opacity: 0;
  transform: translateY(-100%);
  transition:
    transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 450ms ease,
    visibility 700ms;
}

.menuOpen {
  visibility: visible;
  opacity: 1;
  transform: translateY(0);
}

.menuClose {
  position: absolute;
  top: 30px;
  right: clamp(28px, 5vw, 80px);
  width: 52px;
  height: 52px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(8, 8, 7, 0.25);
  border-radius: 50%;
  background: transparent;
  color: var(--v3-black);
}

.menuLabel {
  padding-bottom: 22px;
  border-bottom: 1px solid rgba(8, 8, 7, 0.2);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.menuOverlay nav {
  margin: auto 0;
}

.menuOverlay nav a {
  display: grid;
  grid-template-columns: 70px 1fr auto;
  align-items: center;
  padding: 17px 0;
  border-bottom: 1px solid rgba(8, 8, 7, 0.2);
  font-size: clamp(3.1rem, 7vw, 8rem);
  font-weight: 500;
  line-height: 0.9;
  letter-spacing: -0.065em;
}

.menuOverlay nav a > span {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.1em;
}

.menuOverlay nav a svg {
  transition: transform 300ms ease;
}

.menuOverlay nav a:hover svg {
  transform: translate(8px, -8px);
}

.menuFooter {
  display: flex;
  justify-content: space-between;
  gap: 25px;
  padding-top: 22px;
  border-top: 1px solid rgba(8, 8, 7, 0.2);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* Hero */

.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding:
    125px clamp(22px, 3.5vw, 58px)
    42px;
  background: var(--v3-black);
}

.heroMeta {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 24px;
  padding-bottom: 20px;
  color: var(--v3-muted);
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.heroMeta span:nth-child(2) {
  text-align: center;
}

.hero h1 {
  margin: auto 0;
  font-size: clamp(5.4rem, 13.5vw, 16rem);
  font-weight: 500;
  line-height: 0.75;
  letter-spacing: -0.085em;
  text-transform: uppercase;
}

.heroLine {
  display: block;
  overflow: hidden;
  padding: 0.04em 0 0.14em;
}

.heroLine > span {
  display: block;
  width: max-content;
}

.heroLine:nth-child(2) > span {
  margin-left: 16%;
  color: var(--v3-muted);
}

.heroLine:nth-child(3) > span {
  margin-left: 37%;
  color: var(--v3-red);
}

.heroBottom {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: end;
}

.heroBottom p {
  max-width: 450px;
  color: var(--v3-muted);
  font-size: clamp(0.95rem, 1.15vw, 1.1rem);
  line-height: 1.7;
}

.heroBottom a {
  display: inline-flex;
  align-items: center;
  gap: 11px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--v3-ink);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.heroCoordinate {
  position: absolute;
  right: clamp(22px, 3.5vw, 58px);
  bottom: 42%;
  display: flex;
  align-items: center;
  gap: 12px;
  color: var(--v3-muted);
  font-size: 7px;
  font-weight: 700;
  letter-spacing: 0.12em;
  writing-mode: vertical-rl;
}

.heroCoordinate i {
  width: 1px;
  height: 54px;
  background: var(--v3-line);
}

/* Statistics */

.statistics {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 140px 130px 1fr;
  gap: clamp(24px, 4vw, 70px);
  align-items: center;
  padding: clamp(90px, 10vw, 160px)
    clamp(22px, 3.5vw, 58px);
  background: var(--v3-cream);
  color: var(--v3-black);
}

.statControls {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.statControls button {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(8, 8, 7, 0.25);
  border-radius: 50%;
  background: transparent;
  color: var(--v3-black);
  transition:
    background 220ms ease,
    color 220ms ease;
}

.statControls button:hover {
  background: var(--v3-black);
  color: var(--v3-cream);
}

.statCounter {
  display: flex;
  align-items: center;
  gap: 13px;
  font-size: 10px;
  font-weight: 800;
}

.statCounter i {
  width: 1px;
  height: 72px;
  background: rgba(8, 8, 7, 0.25);
  transform: rotate(24deg);
}

.statContent {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: clamp(40px, 7vw, 130px);
  align-items: end;
  animation: stat-enter 550ms
    cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes stat-enter {
  from {
    opacity: 0;
    transform: translateY(35px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.statContent > strong {
  font-size: clamp(10rem, 25vw, 31rem);
  font-weight: 500;
  line-height: 0.62;
  letter-spacing: -0.1em;
}

.statContent h2 {
  max-width: 440px;
  margin: 0 0 24px;
  font-size: clamp(2.5rem, 4.8vw, 6rem);
  font-weight: 500;
  line-height: 0.9;
  letter-spacing: -0.065em;
}

.statContent p {
  max-width: 430px;
  color: rgba(8, 8, 7, 0.58);
  font-size: clamp(0.95rem, 1.1vw, 1.1rem);
  line-height: 1.7;
}

/* Manifesto */

.manifesto {
  min-height: 150vh;
  padding: clamp(130px, 16vw, 260px)
    clamp(22px, 3.5vw, 58px);
  background: var(--v3-black);
  color: var(--v3-ink);
}

.manifestoLabel {
  display: flex;
  justify-content: space-between;
  gap: 30px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--v3-line);
  color: var(--v3-muted);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.manifesto h2 {
  max-width: 1500px;
  margin: clamp(100px, 12vw, 180px) 0;
  font-size: clamp(3.3rem, 7.4vw, 9rem);
  font-weight: 500;
  line-height: 1;
  letter-spacing: -0.067em;
}

.manifestoLine {
  display: block;
}

.manifestoLine:nth-child(3) {
  margin-bottom: 0.7em;
  color: var(--v3-red);
}

.manifestoBottom {
  display: grid;
  grid-template-columns: 1fr 0.85fr;
  gap: clamp(50px, 10vw, 180px);
  align-items: end;
}

.founderCard {
  width: min(100%, 560px);
  display: grid;
  grid-template-columns: 170px 1fr;
  align-items: end;
  gap: 25px;
}

.founderImage {
  aspect-ratio: 0.82;
  display: grid;
  place-items: end start;
  padding: 17px;
  background: var(--v3-red);
  color: #ffffff;
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.05em;
}

.founderCard > div {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.founderCard strong {
  font-size: 0.95rem;
}

.founderCard div span {
  color: var(--v3-muted);
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.manifestoBottom > p {
  max-width: 600px;
  color: var(--v3-muted);
  font-size: clamp(1.15rem, 1.8vw, 1.8rem);
  line-height: 1.55;
}

/* Next-section placeholder */

.nextSection {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: clamp(90px, 10vw, 160px)
    clamp(22px, 3.5vw, 58px);
  background: var(--v3-red);
  color: #ffffff;
}

.nextSection > span {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.nextSection h2 {
  max-width: 1400px;
  margin: 0;
  font-size: clamp(5rem, 11vw, 13rem);
  font-weight: 500;
  line-height: 0.82;
  letter-spacing: -0.08em;
}

@media (max-width: 900px) {
  .header {
    grid-template-columns: 1fr auto;
  }

  .navigation {
    display: none;
  }

  .hero h1 {
    font-size: clamp(5rem, 17vw, 9rem);
  }

  .heroLine:nth-child(2) > span,
  .heroLine:nth-child(3) > span {
    margin-left: 0;
  }

  .statistics {
    grid-template-columns: 90px 1fr;
  }

  .statCounter {
    display: none;
  }

  .statContent {
    grid-template-columns: 1fr;
  }

  .statContent > strong {
    font-size: clamp(11rem, 38vw, 20rem);
  }

  .manifestoBottom {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 600px) {
  .header {
    height: 76px;
  }

  .menuButton span {
    display: none;
  }

  .hero {
    padding-top: 105px;
  }

  .heroMeta {
    grid-template-columns: 1fr auto;
  }

  .heroMeta span:nth-child(2) {
    display: none;
  }

  .hero h1 {
    font-size: clamp(4.2rem, 19vw, 6.2rem);
    line-height: 0.82;
  }

  .heroBottom {
    grid-template-columns: 1fr;
  }

  .heroCoordinate {
    display: none;
  }

  .statistics {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .statControls {
    flex-direction: row;
  }

  .manifesto {
    min-height: 100vh;
  }

  .manifesto h2 {
    font-size: clamp(3.1rem, 13vw, 5rem);
  }

  .founderCard {
    grid-template-columns: 115px 1fr;
  }

  .menuOverlay nav a {
    grid-template-columns: 40px 1fr auto;
    font-size: clamp(2.7rem, 13vw, 4.5rem);
  }

  .menuFooter {
    align-items: flex-start;
    flex-direction: column;
  }
}

@media (prefers-reduced-motion: reduce) {
  .brand,
  .navigation a,
  .menuButton,
  .heroLine span,
  .heroMeta,
  .heroBottom,
  .manifestoLine,
  .founderCard {
    opacity: 1 !important;
    transform: none !important;
  }
}

.nextSection {
  display: none !important;
}

.headerActions {
  justify-self: end;
  display: flex;
  align-items: center;
  gap: 10px;
}

.headerActions .menuButton {
  justify-self: auto;
}

.themeToggle {
  width: 43px;
  height: 43px;
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  color: var(--v3-ink);
  background: transparent;
  border: 1px solid var(--v3-line);
  border-radius: 50%;
  cursor: pointer;
  transition:
    color 250ms ease,
    background 250ms ease,
    transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

.themeToggle:hover {
  color: var(--v3-black);
  background: var(--v3-ink);
  transform: rotate(18deg);
}


@media (max-width: 620px) {
  .headerActions {
    gap: 7px;
  }

  .themeToggle {
    width: 39px;
    height: 39px;
  }
}




/* CINEMATIC STICKY FIX */

.site {
  overflow: clip;
}

/* Keep header separate from hero video */
.header {
  background: #080808;
}

.site > main {
  padding-top: 92px;
}

/* V3 MANIFESTO COMPACT START */
.manifesto {
  height: auto;
  min-height: auto;
  padding-top: clamp(70px, 7vw, 110px);
  padding-bottom: clamp(70px, 7vw, 110px);
}

.manifesto h2 {
  margin-bottom: clamp(40px, 4vw, 64px);
}
/* V3 MANIFESTO COMPACT END */

/* MANIFESTO BODY RIGHT START */
.manifestoBottom {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}

.manifestoBottom p {
  margin-left: auto;
  margin-right: 0;
  max-width: 560px;
  text-align: right;
}
/* MANIFESTO BODY RIGHT END */

/* MANIFESTO OPACITY START */
.manifestoLine {
  opacity: 0.1;
  will-change: opacity;
}
/* MANIFESTO OPACITY END */

/* V3 META ROW RHYTHM START */
.manifesto {
  padding-top: 0 !important;
}

.manifestoLabel {
  height: clamp(60px, 4.25vw, 66px) !important;
  min-height: clamp(60px, 4.25vw, 66px) !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  align-items: center !important;
  box-sizing: border-box;
}

.manifestoLabel > * {
  margin-top: 0 !important;
  margin-bottom: 0 !important;
}
/* V3 META ROW RHYTHM END */

/* V3 HEADER CONTACT START */
.navigation .contactLink {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0 18px;
  margin-left: 8px;
  border: 1px solid currentColor;
  border-radius: 999px;
  transition:
    color 220ms ease,
    background-color 220ms ease,
    border-color 220ms ease;
}

.navigation .contactLink:hover {
  color: var(--v3-paper);
  background: var(--v3-ink);
}

:global(html[data-v3-theme="light"])
.navigation .contactLink:hover {
  color: #f2efe8;
  background: #080807;
}
/* V3 HEADER CONTACT END */

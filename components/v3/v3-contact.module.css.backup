.contact {
  --contact-red: #b91622;
  --contact-dark: #0b0a09;
  --contact-cream: #eeeae2;
  --contact-line: rgba(238, 234, 226, 0.18);
  position: relative;
  overflow: hidden;
  color: var(--contact-cream);
  background: var(--contact-red);
}

.topbar {
  min-height: 72px;
  padding: 0 4.5vw;
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  align-items: center;
  border-bottom: 1px solid rgba(238, 234, 226, 0.3);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.17em;
}

.topbar span:nth-child(2) {
  justify-self: center;
}

.intro {
  padding: 8vh 4.5vw 3vh;
  display: grid;
  grid-template-columns: 35% 1fr;
}

.eyebrow {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.18em;
}

.intro p {
  margin: 0;
  max-width: 550px;
  font-size: clamp(1.15rem, 1.55vw, 1.6rem);
  line-height: 1.5;
}

.cta {
  --pointer-x: 50%;
  --pointer-y: 50%;
  position: relative;
  min-height: 68vh;
  padding: 5vh 4.5vw 7vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  color: var(--contact-cream);
  border-bottom: 1px solid rgba(238, 234, 226, 0.3);
  text-decoration: none;
  cursor: pointer;
  isolation: isolate;
}

.ctaLabel {
  position: absolute;
  top: 5vh;
  left: 4.5vw;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.18em;
}

.cta strong {
  position: relative;
  z-index: 2;
  font-size: clamp(4.5rem, 9.3vw, 11rem);
  font-weight: 400;
  line-height: 0.82;
  letter-spacing: -0.085em;
}

.cta strong em {
  color: var(--contact-dark);
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 400;
}

.ctaArrow {
  position: absolute;
  right: 4.5vw;
  bottom: 7vh;
  z-index: 3;
  width: 88px;
  height: 88px;
  display: grid;
  place-items: center;
  color: var(--contact-red);
  background: var(--contact-cream);
  border-radius: 50%;
  transition:
    color 400ms ease,
    background 400ms ease,
    transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
}

.cta:hover .ctaArrow {
  color: var(--contact-cream);
  background: var(--contact-dark);
  transform: rotate(45deg) scale(1.08);
}

.pointer {
  position: absolute;
  top: var(--pointer-y);
  left: var(--pointer-x);
  z-index: 0;
  width: 240px;
  height: 240px;
  background: var(--contact-dark);
  border-radius: 50%;
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.3);
  transition:
    opacity 300ms ease,
    transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  pointer-events: none;
}

.cta:hover .pointer {
  opacity: 0.08;
  transform: translate(-50%, -50%) scale(1);
}

.details {
  min-height: 220px;
  padding: 0 4.5vw;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.4fr auto;
  align-items: stretch;
  border-bottom: 1px solid rgba(238, 234, 226, 0.3);
}

.detailBlock {
  padding: 3.5rem 3vw 3rem 0;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  justify-content: center;
  border-right: 1px solid rgba(238, 234, 226, 0.25);
}

.detailBlock + .detailBlock {
  padding-left: 3vw;
}

.detailBlock > span {
  opacity: 0.66;
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.18em;
}

.detailBlock a,
.detailBlock p {
  margin: 0;
  color: var(--contact-cream);
  font-size: clamp(0.95rem, 1.15vw, 1.2rem);
  line-height: 1.5;
  text-decoration: none;
}

.detailBlock a {
  width: fit-content;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid rgba(238, 234, 226, 0.55);
}

.backTop {
  min-width: 150px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.7rem;
  color: var(--contact-cream);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-decoration: none;
  text-transform: uppercase;
}

.backTop svg {
  transition: transform 300ms ease;
}

.backTop:hover svg {
  transform: translateY(-6px);
}

.footerBottom {
  min-height: 310px;
  padding: 5rem 4.5vw 3rem;
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: 1fr auto;
  gap: 3rem;
  color: var(--contact-cream);
  background: var(--contact-dark);
}

.brand {
  width: fit-content;
  display: flex;
  align-items: center;
  gap: 1rem;
  color: inherit;
  text-decoration: none;
}

.brand > span {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  color: var(--contact-dark);
  background: var(--contact-cream);
  font-size: 1.25rem;
  font-weight: 800;
}

.brand strong {
  display: flex;
  flex-direction: column;
  font-size: 13px;
  letter-spacing: 0.08em;
}

.brand small {
  margin-top: 0.3rem;
  color: #73706b;
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 0.04em;
}

.footerBottom nav {
  display: flex;
  align-items: flex-start;
  gap: clamp(1.2rem, 2.6vw, 3rem);
}

.footerBottom nav a {
  position: relative;
  padding-bottom: 0.5rem;
  color: #8b8882;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-decoration: none;
  text-transform: uppercase;
  transition: color 250ms ease;
}

.footerBottom nav a:hover {
  color: var(--contact-cream);
}

.legal {
  grid-column: 1 / -1;
  padding-top: 1.5rem;
  display: flex;
  justify-content: space-between;
  color: #65625d;
  border-top: 1px solid var(--contact-line);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

@media (max-width: 900px) {
  .topbar {
    grid-template-columns: 1fr auto;
  }

  .topbar span:nth-child(2) {
    display: none;
  }

  .intro {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .cta {
    min-height: 60vh;
  }

  .cta strong {
    font-size: clamp(4.5rem, 13vw, 8rem);
  }

  .details {
    grid-template-columns: 1fr 1fr;
  }

  .detailBlock:nth-child(2) {
    border-right: 0;
  }

  .detailBlock:nth-child(3) {
    padding-left: 0;
    border-top: 1px solid rgba(238, 234, 226, 0.25);
  }

  .backTop {
    border-top: 1px solid rgba(238, 234, 226, 0.25);
  }
}

@media (max-width: 620px) {
  .topbar {
    min-height: 58px;
    padding-inline: 5vw;
  }

  .intro {
    padding-inline: 5vw;
  }

  .cta {
    min-height: 64vh;
    padding-inline: 5vw;
  }

  .cta strong {
    font-size: clamp(4rem, 18vw, 6rem);
  }

  .ctaArrow {
    right: 5vw;
    width: 64px;
    height: 64px;
  }

  .pointer {
    display: none;
  }

  .details {
    padding-inline: 5vw;
    display: block;
  }

  .detailBlock,
  .detailBlock + .detailBlock {
    padding: 2.2rem 0;
    border-right: 0;
    border-bottom: 1px solid rgba(238, 234, 226, 0.25);
  }

  .backTop {
    min-height: 95px;
    justify-content: space-between;
    border-top: 0;
  }

  .footerBottom {
    padding-inline: 5vw;
    display: flex;
    flex-direction: column;
  }

  .footerBottom nav {
    flex-wrap: wrap;
    line-height: 2;
  }

  .legal {
    margin-top: auto;
    flex-direction: column;
    gap: 0.8rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .pointer {
    display: none;
  }
}

.wordmark {
  --spot-x: 50%;
  --spot-y: 50%;
  grid-column: 1 / -1;
  position: relative;
  height: clamp(150px, 21vw, 370px);
  margin: 1rem -4.5vw -3rem;
  overflow: hidden;
  cursor: crosshair;
  user-select: none;
}

.wordmarkBase,
.wordmarkReveal {
  position: absolute;
  left: 50%;
  bottom: -0.04em;
  width: max-content;
  font-size: clamp(8rem, 22.5vw, 28rem);
  font-weight: 700;
  line-height: 0.72;
  letter-spacing: -0.085em;
  transform: translateX(-50%);
  pointer-events: none;
}

.wordmarkBase {
  color: #171614;
  -webkit-text-stroke: 1px rgba(238, 234, 226, 0.045);
}

.wordmarkReveal {
  color: #b91622;
  opacity: 0;
  mask-image: radial-gradient(
    circle 150px at var(--spot-x) var(--spot-y),
    #000 0%,
    #000 52%,
    transparent 100%
  );
  -webkit-mask-image: radial-gradient(
    circle 150px at var(--spot-x) var(--spot-y),
    #000 0%,
    #000 52%,
    transparent 100%
  );
  transition: opacity 220ms ease;
}

.wordmark:hover .wordmarkReveal {
  opacity: 1;
}

@media (max-width: 620px) {
  .wordmark {
    height: 130px;
    margin-inline: -5vw;
  }

  .wordmarkBase,
  .wordmarkReveal {
    font-size: clamp(7rem, 25vw, 10rem);
  }

  .wordmarkReveal {
    display: none;
  }
}

/* Fix oversized wordmark kerning seams */
.wordmarkBase,
.wordmarkReveal {
  letter-spacing: -0.035em;
  font-kerning: normal;
  font-feature-settings: "kern" 1;
  text-rendering: geometricPrecision;
  -webkit-text-stroke: 0;
  transform: translate3d(-50%, 0, 0);
  backface-visibility: hidden;
}

.wordmarkBase {
  -webkit-text-stroke: 0;
}

/* V3 global office footer */

.footerBottom {
  min-height: auto;
  padding: clamp(4rem, 6vw, 7rem) 4.5vw 3rem;
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: auto;
  gap: 2.5rem;
}

.footerMain {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(520px, 1.05fr);
  gap: clamp(3rem, 6vw, 8rem);
  padding-bottom: clamp(4rem, 6vw, 7rem);
}

.footerColumns {
  display: grid;
  grid-template-columns: 0.72fr 1fr 1.45fr;
  gap: clamp(1.5rem, 3vw, 4rem);
  align-items: start;
}

.linkGroup {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.72rem;
}

.linkGroup > span {
  margin-bottom: 1rem;
  color: #65625d;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.16em;
}

.linkGroup a {
  position: relative;
  color: #aaa69f;
  font-size: clamp(12px, 0.84vw, 15px);
  line-height: 1.35;
  text-decoration: none;
  transition:
    color 250ms ease,
    transform 250ms ease;
}

.linkGroup a:hover {
  color: var(--contact-cream);
  transform: translateX(5px);
}

.linkGroup p {
  margin: 0.7rem 0 0;
  color: #75716b;
  font-size: clamp(10px, 0.7vw, 12px);
  line-height: 1.75;
}

.worldPanel {
  position: relative;
  min-height: 365px;
  padding-left: clamp(2rem, 4vw, 5rem);
  overflow: hidden;
  border-left: 1px solid var(--contact-line);
}

.mapHeading {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 2rem;
}

.mapHeading span {
  color: #66625d;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.16em;
}

.mapHeading strong {
  max-width: 250px;
  color: var(--contact-cream);
  font-size: clamp(1.2rem, 1.55vw, 1.8rem);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.035em;
}

.worldMap {
  width: 100%;
  height: auto;
  margin-top: 1.5rem;
  overflow: visible;
}

.mapGrid path {
  fill: none;
  stroke: rgba(238, 234, 226, 0.035);
  stroke-width: 1;
  vector-effect: non-scaling-stroke;
}

.continents path {
  fill: rgba(238, 234, 226, 0.025);
  stroke: rgba(238, 234, 226, 0.22);
  stroke-width: 1.25;
  stroke-linejoin: round;
  vector-effect: non-scaling-stroke;
  transition:
    fill 500ms ease,
    stroke 500ms ease;
}

.worldPanel:hover .continents path {
  fill: rgba(238, 234, 226, 0.045);
  stroke: rgba(238, 234, 226, 0.34);
}

.officeConnection path {
  fill: none;
  stroke: rgba(190, 22, 34, 0.45);
  stroke-width: 1.2;
  stroke-dasharray: 4 7;
  vector-effect: non-scaling-stroke;
}

.mapMarker text {
  fill: #aaa69f;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.13em;
}

.mapDot {
  fill: #c31623;
  stroke: #f1ede4;
  stroke-width: 2;
  vector-effect: non-scaling-stroke;
}

.mapPulse,
.mapPulseDelay {
  fill: none;
  stroke: #c31623;
  stroke-width: 2;
  opacity: 0;
  transform-box: fill-box;
  transform-origin: center;
  animation: officePulse 2.8s cubic-bezier(0.2, 0.65, 0.3, 1) infinite;
  vector-effect: non-scaling-stroke;
}

.mapPulseDelay {
  animation-delay: 1.4s;
}

.mapLocations {
  display: flex;
  justify-content: space-between;
  gap: 1.5rem;
  color: #5f5c57;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.11em;
}

.mapLocations span {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
}

.mapLocations i {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #c31623;
  box-shadow: 0 0 14px rgba(195, 22, 35, 0.75);
}

.legal {
  grid-column: auto;
}

.wordmark {
  grid-column: auto;
}

@keyframes officePulse {
  0% {
    opacity: 0.85;
    transform: scale(0.35);
  }

  75%,
  100% {
    opacity: 0;
    transform: scale(3.3);
  }
}

@media (max-width: 1180px) {
  .footerMain {
    grid-template-columns: 1fr;
  }

  .worldPanel {
    min-height: auto;
    padding: 3rem 0 0;
    border-top: 1px solid var(--contact-line);
    border-left: 0;
  }
}

@media (max-width: 760px) {
  .footerBottom {
    padding-inline: 5vw;
    display: grid;
  }

  .footerColumns {
    grid-template-columns: 1fr 1fr;
    row-gap: 3rem;
  }

  .linkGroup:last-child {
    grid-column: 1 / -1;
  }

  .mapHeading {
    flex-direction: column;
  }

  .mapHeading strong {
    max-width: 100%;
  }

  .mapMarker text {
    display: none;
  }

  .mapLocations {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .footerColumns {
    grid-template-columns: 1fr;
  }

  .linkGroup:last-child {
    grid-column: auto;
  }

  .worldMap {
    width: 125%;
    margin-left: -12.5%;
  }
}

@media (prefers-reduced-motion: reduce) {
  .mapPulse,
  .mapPulseDelay {
    animation: none;
  }
}
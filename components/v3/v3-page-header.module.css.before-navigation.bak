.header {
  position: relative;
  z-index: 70;
  width: 100%;
  height: 92px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 32px;
  padding: 0 clamp(22px, 3.5vw, 58px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  background: #080808;
  color: #f4f1eb;
}

.brand {
  width: fit-content;
  display: inline-flex;
  align-items: center;
  gap: 14px;
  color: inherit;
  text-decoration: none;
}

.brandMark {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  background: #f2efe9;
  color: #090909;
  font-size: 16px;
  font-weight: 700;
}

.brandText {
  display: grid;
  gap: 3px;
}

.brandText strong {
  font-size: 12px;
  letter-spacing: 0.08em;
}

.brandText small {
  color: rgba(244, 241, 235, 0.42);
  font-size: 9px;
}

.navigation {
  display: flex;
  align-items: center;
  gap: clamp(20px, 2.5vw, 42px);
}

.navigation a {
  position: relative;
  padding: 8px 0;
  color: rgba(244, 241, 235, 0.48);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-decoration: none;
  text-transform: uppercase;
  transition: color 220ms ease;
}

.navigation a::after {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 1px;
  content: "";
  background: #c81420;
  transform: scaleX(0);
  transform-origin: right;
  transition: transform 350ms cubic-bezier(0.22, 1, 0.36, 1);
}

.navigation a:hover,
.navigation a.active {
  color: #f4f1eb;
}

.navigation a:hover::after,
.navigation a.active::after {
  transform: scaleX(1);
  transform-origin: left;
}

.actions {
  justify-self: end;
  display: flex;
  align-items: center;
  gap: 10px;
}

.themeButton,
.menuButton {
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: transparent;
  color: #f4f1eb;
  cursor: pointer;
}

.themeButton {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  border-radius: 50%;
}

.menuButton {
  height: 46px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0 18px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.themeButton:hover,
.menuButton:hover {
  background: #f4f1eb;
  color: #090909;
}

.menuOverlay {
  position: fixed;
  z-index: 200;
  inset: 0;
  display: flex;
  flex-direction: column;
  padding: clamp(28px, 5vw, 80px);
  background: #ece9e2;
  color: #090909;
  visibility: hidden;
  opacity: 0;
  transform: translateY(-100%);
  transition:
    transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 400ms ease,
    visibility 700ms;
}

.menuOpen {
  visibility: visible;
  opacity: 1;
  transform: translateY(0);
}

.menuClose {
  position: absolute;
  top: clamp(24px, 4vw, 52px);
  right: clamp(24px, 4vw, 58px);
  width: 52px;
  height: 52px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(0, 0, 0, 0.18);
  border-radius: 50%;
  background: transparent;
  color: #090909;
  cursor: pointer;
}

.menuLabel {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.menuOverlay nav {
  width: 100%;
  margin: auto 0;
}

.menuOverlay nav a {
  display: grid;
  grid-template-columns: 70px 1fr auto;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.14);
  color: #090909;
  text-decoration: none;
}

.menuOverlay nav a span {
  color: rgba(0, 0, 0, 0.44);
  font-size: 10px;
}

.menuOverlay nav a strong {
  font-size: clamp(40px, 7vw, 108px);
  font-weight: 400;
  letter-spacing: -0.055em;
  line-height: 0.9;
}

.menuOverlay nav a i {
  font-size: 28px;
  font-style: normal;
  transition: transform 250ms ease;
}

.menuOverlay nav a:hover i {
  transform: translate(6px, -6px);
}

.menuFooter {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

:global(html[data-v3-theme="light"]) .header {
  border-color: rgba(0, 0, 0, 0.12);
  background: #f0ede6;
  color: #111;
}

:global(html[data-v3-theme="light"]) .brandMark {
  background: #111;
  color: #f0ede6;
}

:global(html[data-v3-theme="light"]) .brandText small,
:global(html[data-v3-theme="light"]) .navigation a {
  color: rgba(0, 0, 0, 0.48);
}

:global(html[data-v3-theme="light"]) .navigation a:hover,
:global(html[data-v3-theme="light"]) .navigation a.active {
  color: #111;
}

:global(html[data-v3-theme="light"]) .themeButton,
:global(html[data-v3-theme="light"]) .menuButton {
  border-color: rgba(0, 0, 0, 0.16);
  color: #111;
}

@media (max-width: 900px) {
  .header {
    grid-template-columns: 1fr auto;
    height: 78px;
  }

  .navigation {
    display: none;
  }

  .themeButton {
    display: none;
  }
}

@media (max-width: 560px) {
  .brandText {
    display: none;
  }

  .menuOverlay nav a {
    grid-template-columns: 42px 1fr auto;
  }

  .menuFooter {
    flex-direction: column;
  }
}